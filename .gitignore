# ============================================
# PRISON REHAB SYSTEM - .gitignore
# ============================================

# === Environment Variables (CRITICAL - Contains Passwords!) ===
.env
.env.local
.env.production
.env.development

# === Node.js Dependencies ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# === Uploaded Files (User uploaded images) ===
uploads/
uploads/*
!uploads/.gitkeep

# === Logs ===
logs/
*.log
*.log.*

# === OS Generated Files ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# === IDE / Editor Files ===
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# === Backup Files ===
*.bak
*.backup
*.old
*.orig

# === Database Files ===
*.sql
*.dump
*.db
*.sqlite
*.sqlite3

# === Runtime Data ===
pids
*.pid
*.seed
*.pid.lock

# === Coverage Directory (Testing) ===
coverage/
.nyc_output/

# === Build Outputs ===
dist/
build/
out/

# === Railway / Deployment Specific ===
.railway/
railway.json

# === Temporary Files ===
tmp/
temp/
*.tmp
*.temp

# === Session Files ===
sessions/
session-store/

# === Certificates ===
*.pem
*.key
*.crt
*.cert

# === Secret Files ===
secrets.json
secret-key.txt
credentials.json
